{
  "info": {
    "name": "Job Portal API",
    "description": "Postman collection for testing the Spring Boot Job Portal. Note: Because the backend uses Session IDs, you must run the Login request before running other authenticated requests.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "User Endpoints",
      "item": [
        {
          "name": "User Signup",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "name", "value": "Test User", "type": "text" },
                { "key": "email", "value": "testuser@example.com", "type": "text" },
                { "key": "mobile", "value": "1234567890", "type": "text" },
                { "key": "password", "value": "password123", "type": "text" },
                { "key": "dob", "value": "2000-01-01", "type": "text" },
                { "key": "gender", "value": "male", "type": "text" }
              ]
            },
            "url": {
              "raw": "http://localhost:8081/user/signup",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8081",
              "path": ["user", "signup"]
            }
          }
        },
        {
          "name": "User Login",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "email", "value": "testuser@example.com", "type": "text" },
                { "key": "password", "value": "password123", "type": "text" }
              ]
            },
            "url": {
              "raw": "http://localhost:8081/user/login",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8081",
              "path": ["user", "login"]
            }
          }
        },
        {
          "name": "View Jobs (Requires Login)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:8081/user/view-jobs",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8081",
              "path": ["user", "view-jobs"]
            }
          }
        }
      ]
    },
